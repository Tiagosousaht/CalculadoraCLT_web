{
  "framework": null,
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "buildCommand": "npx expo export --platform web",
  "env": {
    "EXPO_PUBLIC_PLATFORM": "web"
  },
  "rewrites": [
    {
      "source": "/((?!ads.txt|robots.txt|sitemap.xml|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}